# =========================================================
# Sooly · repo-root .gitignore
# (web/ 안에는 create-next-app 이 만든 자체 .gitignore 가 있음)
# =========================================================

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Env
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Supabase CLI
supabase/.branches
supabase/.temp
supabase/.env

# Data dumps (1,251 raw xlsx 는 깃에 넣지 말고 별도 백업)
scripts/data/*.xlsx
scripts/data/*.csv
scripts/data/*.json
!scripts/data/.gitkeep

# Misc
.cache/
.vercel
